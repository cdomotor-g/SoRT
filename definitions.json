  "propertyServices": {
    "title": "Property Services Instruction",
    "note": "Property Services conducts its due diligence and secures tenure agreements based on the information provided in this Site Assessment. If there have been any changes to the coordinates since the completion date of this site assessment, you must inform Property Services (FWINLeasing@bom.gov.au) to ensure that the due diligence performed remains valid.",
    "rows": [
      {
        "id": "currentCoords",
        "kind": "coordGroup",
        "label": "Current Co-Ordinates",
        "coords": [
          {
            "key": "primary",
            "label": "Primary (main equipment)",
            "source": {
              "row": "coords",
              "field": "existing"
            }
          },
          {
            "key": "subsidiary",
            "label": "Subsidiary (orifice line)",
            "source": {
              "row": "riverCoords",
              "field": "detail"
            }
          }
        ]
      },
      {
        "id": "relocating",
        "kind": "question",
        "label": "Is the equipment being relocated?",
        "linkedNote": "Preselected from the Relocation answer in the table above — change it here if this differs.",
        "options": [
          "Yes",
          "No"
        ],
        "source": {
          "row": "relocation",
          "field": null
        }
      },
      {
        "id": "relocationCoords",
        "kind": "coordGroup",
        "label": "Relocation Co-Ordinates",
        "coords": [
          {
            "key": "primary",
            "label": "Primary (main equipment)",
            "source": {
              "row": "relocation",
              "field": "newLocation"
            },
            "default": "na"
          },
          {
            "key": "orifice",
            "label": "Orifice line termination or GCO",
            "source": {
              "row": "riverCoords",
              "field": null
            },
            "default": "na"
          },
          {
            "key": "raingauge",
            "label": "Rain gauge (if not located at primary)",
            "default": "na"
          }
        ]
      },
      {
        "id": "turnSoil",
        "kind": "question",
        "label": "Does the work require the turning of soil?",
        "required": true,
        "options": [
          "Yes",
          "No"
        ]
      },
      {
        "id": "wlHeader",
        "kind": "sectionHeader",
        "label": "Water Level site details only",
        "wlOnly": true
      },
      {
        "id": "orificeReplace",
        "kind": "question",
        "label": "Will the orifice line be replaced?",
        "wlOnly": true,
        "required": true,
        "options": [
          "Yes",
          "No"
        ]
      },
      {
        "id": "orificeDirection",
        "kind": "text",
        "label": "What direction does the orifice line run from the primary equipment?",
